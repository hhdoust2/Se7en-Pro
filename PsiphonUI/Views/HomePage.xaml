<UserControl x:Class="PsiphonUI.Views.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:PsiphonUI.Converters"
             xmlns:vm="clr-namespace:PsiphonUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:HomeViewModel}">

    <UserControl.Resources>
        <conv:StateToButtonTextConverter x:Key="StateToButtonText" />
        <conv:StateToBrushConverter x:Key="StateToBrush" />
        <conv:StateToConnectButtonBrushConverter x:Key="StateToConnectBrush" />
        <conv:InverseBoolConverter x:Key="InverseBool" />
        <conv:CountryCodeToFlagSourceConverter x:Key="CountryCodeToFlag" />
    </UserControl.Resources>

<ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24,16,24,20" MinHeight="560">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="260" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

<StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Grid HorizontalAlignment="Center" Width="240" Height="240">
                <Ellipse Width="240" Height="240"
                         Stroke="{Binding State, Converter={StaticResource StateToConnectBrush}}"
                         StrokeThickness="1.5"
                         Opacity="0.25" />
                <ProgressBar Width="228" Height="228"
                             Style="{StaticResource MaterialDesignCircularProgressBar}"
                             IsIndeterminate="True"
                             Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                             Foreground="{StaticResource Brand.AccentBrush}" />

                <Button Style="{StaticResource UI.ConnectButton}"
                        Command="{Binding ToggleConnectionCommand}"
                        Content="{Binding State, Converter={StaticResource StateToButtonText}}"
                        Background="{Binding State, Converter={StaticResource StateToConnectBrush}}" />
            </Grid>

<Border Background="{DynamicResource Surface.SubtleBg}"
                    BorderBrush="{DynamicResource Surface.SubtleBorder}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14,7"
                    HorizontalAlignment="Center"
                    Margin="0,16,0,0">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="9" Height="9" VerticalAlignment="Center"
                             Fill="{Binding State, Converter={StaticResource StateToBrush}}" />
                    <TextBlock Text="{Binding StatusText}" Margin="8,0,0,0"
                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </StackPanel>

<Grid Grid.Row="1"
              HorizontalAlignment="Stretch"
              MaxWidth="720"
              Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource UI.Card}"
                    HorizontalAlignment="Stretch"
                    Padding="14,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="34" Height="34"
                            CornerRadius="8"
                            Background="{DynamicResource Surface.SubtleBg}"
                            BorderBrush="{DynamicResource Surface.SubtleBorder}"
                            BorderThickness="1"
                            VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="EarthArrowRight"
                                                 Width="19" Height="19"
                                                 VerticalAlignment="Center"
                                                 HorizontalAlignment="Center"
                                                 Foreground="{StaticResource Brand.AccentBrush}" />
                    </Border>

                    <StackPanel Grid.Column="1"
                                Margin="10,0,10,0"
                                VerticalAlignment="Center">
                        <TextBlock Text="Region"
                                   FontSize="14" FontWeight="SemiBold" />
                        <TextBlock Text="Exit country."
                                   FontSize="12" Opacity="0.7" Margin="0,2,0,0"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <ComboBox Grid.Column="2"
                              ItemsSource="{Binding EgressRegions}"
                              SelectedValue="{Binding SelectedEgressRegion, Mode=TwoWay}"
                              SelectedValuePath="Code"
                              VerticalAlignment="Center"
                              MinHeight="34"
                              MinWidth="120"
                              ToolTip="Change the exit country. The tunnel will restart if currently connected.">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Image Width="20" Height="14" Margin="0,0,8,0"
                                           VerticalAlignment="Center"
                                           SnapsToDevicePixels="True"
                                           RenderOptions.BitmapScalingMode="Linear"
                                           Source="{Binding Code, Converter={StaticResource CountryCodeToFlag}}" />
                                    <TextBlock Text="{Binding Name}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource UI.Card}"
                    HorizontalAlignment="Stretch"
                    Padding="14,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="34" Height="34"
                            CornerRadius="8"
                            Background="{DynamicResource Surface.SubtleBg}"
                            BorderBrush="{DynamicResource Surface.SubtleBorder}"
                            BorderThickness="1"
                            VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="ShieldLockOutline"
                                                 Width="19" Height="19"
                                                 VerticalAlignment="Center"
                                                 HorizontalAlignment="Center"
                                                 Foreground="{StaticResource Brand.AccentBrush}" />
                    </Border>

                    <StackPanel Grid.Column="1"
                                Margin="10,0,10,0"
                                VerticalAlignment="Center">
                        <TextBlock Text="System tunnel"
                                   FontSize="14" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                                     Fill="{Binding TunStatusBrush}" />
                            <TextBlock Text="{Binding TunStatusText}"
                                       Margin="6,0,0,0"
                                       FontSize="12" Opacity="0.75"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>

                    <ToggleButton Grid.Column="2"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  IsChecked="{Binding TunModeEnabled, Mode=TwoWay}"
                                  IsEnabled="{Binding IsAdminElevated}"
                                  VerticalAlignment="Center"
                                  ToolTip="Route every app's traffic through PsiphonUI (needs Administrator)" />
                </Grid>
            </Border>
        </Grid>

<Border Grid.Row="2"
                Style="{StaticResource UI.Card}"
                HorizontalAlignment="Stretch"
                MaxWidth="720"
                Margin="0,12,0,0"
                Padding="18,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

<Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Style="{StaticResource UI.SectionLabel}" Text="REGION" />

                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Image Width="22" Height="16" Margin="0,0,8,0"
                                   VerticalAlignment="Center"
                                   SnapsToDevicePixels="True"
                                   RenderOptions.BitmapScalingMode="Linear"
                                   Visibility="{Binding HasRegion, Converter={StaticResource BooleanToVisibilityConverter}}"
                                   Source="{Binding ServerRegionCode, Converter={StaticResource CountryCodeToFlag}}" />
                            <TextBlock Text="{Binding ServerRegionName}"
                                       FontSize="16" FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="Exit server region" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="8,0,8,0">
                        <TextBlock Style="{StaticResource UI.SectionLabel}" Text="UPTIME" />
                        <TextBlock Text="{Binding UptimeText}"
                                   FontFamily="Cascadia Mono, Consolas, monospace"
                                   FontSize="16" FontWeight="SemiBold"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="8,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ArrowDown" Width="12" Height="12"
                                                      VerticalAlignment="Center" Opacity="0.7" />
                            <TextBlock Style="{StaticResource UI.SectionLabel}"
                                       Text="DOWNLOAD"
                                       Margin="3,0,0,0" />
                        </StackPanel>
                        <TextBlock Text="{Binding DownSpeedText}"
                                   FontFamily="Cascadia Mono, Consolas, monospace"
                                   FontSize="16" FontWeight="SemiBold"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ArrowUp" Width="12" Height="12"
                                                      VerticalAlignment="Center" Opacity="0.7" />
                            <TextBlock Style="{StaticResource UI.SectionLabel}"
                                       Text="UPLOAD"
                                       Margin="3,0,0,0" />
                        </StackPanel>
                        <TextBlock Text="{Binding UpSpeedText}"
                                   FontFamily="Cascadia Mono, Consolas, monospace"
                                   FontSize="16" FontWeight="SemiBold"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>

<Grid Grid.Row="1" Margin="0,10,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

<TextBlock Grid.Column="0" />
                    <TextBlock Grid.Column="1" />

                    <StackPanel Grid.Column="2" Margin="8,0,8,0">
                        <TextBlock Style="{StaticResource UI.SectionLabel}" Text="TOTAL DOWN" />
                        <TextBlock Text="{Binding TotalDownText}"
                                   FontFamily="Cascadia Mono, Consolas, monospace"
                                   FontSize="13" Opacity="0.85"
                                   Margin="0,2,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="8,0,0,0">
                        <TextBlock Style="{StaticResource UI.SectionLabel}" Text="TOTAL UP" />
                        <TextBlock Text="{Binding TotalUpText}"
                                   FontFamily="Cascadia Mono, Consolas, monospace"
                                   FontSize="13" Opacity="0.85"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </Grid>

<StackPanel Grid.Row="2">
                    <Border Background="{DynamicResource Surface.SubtleBorder}" Height="1" Margin="0,0,0,12" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

<Grid Grid.Column="0" Margin="0,0,8,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="54" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="HTTP"
                                       FontSize="11" FontWeight="SemiBold" Opacity="0.7"
                                       VerticalAlignment="Center" />
                            <Border Grid.Column="1" Style="{StaticResource UI.MonoPill}">
                                <TextBlock Style="{StaticResource UI.MonoText}"
                                           Text="{Binding HttpProxyEndpoint}"
                                           TextTrimming="CharacterEllipsis" />
                            </Border>
                            <Button Grid.Column="2"
                                    Style="{StaticResource UI.IconButton}"
                                    Margin="4,0,0,0"
                                    ToolTip="Copy HTTP proxy"
                                    Command="{Binding CopyHttpProxyCommand}">
                                <materialDesign:PackIcon Kind="ContentCopy" Width="15" Height="15" />
                            </Button>
                        </Grid>

<Grid Grid.Column="1" Margin="8,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="54" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="SOCKS"
                                       FontSize="11" FontWeight="SemiBold" Opacity="0.7"
                                       VerticalAlignment="Center" />
                            <Border Grid.Column="1" Style="{StaticResource UI.MonoPill}">
                                <TextBlock Style="{StaticResource UI.MonoText}"
                                           Text="{Binding SocksProxyEndpoint}"
                                           TextTrimming="CharacterEllipsis" />
                            </Border>
                            <Button Grid.Column="2"
                                    Style="{StaticResource UI.IconButton}"
                                    Margin="4,0,0,0"
                                    ToolTip="Copy SOCKS proxy"
                                    Command="{Binding CopySocksProxyCommand}">
                                <materialDesign:PackIcon Kind="ContentCopy" Width="15" Height="15" />
                            </Button>
                        </Grid>
                    </Grid>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" Margin="0,0,8,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="54" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="IP"
                                       FontSize="11" FontWeight="SemiBold" Opacity="0.7"
                                       VerticalAlignment="Center" />
                            <Border Grid.Column="1" Style="{StaticResource UI.MonoPill}">
                                <TextBlock Style="{StaticResource UI.MonoText}"
                                           Text="{Binding CurrentRouteIp}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="Edge IP tunnel-core is currently routing through" />
                            </Border>
                            <Button Grid.Column="2"
                                    Style="{StaticResource UI.IconButton}"
                                    Margin="4,0,0,0"
                                    ToolTip="Copy current edge IP"
                                    Command="{Binding CopyCurrentIpCommand}">
                                <materialDesign:PackIcon Kind="ContentCopy" Width="15" Height="15" />
                            </Button>
                        </Grid>

                        <Grid Grid.Column="1" Margin="8,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="54" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="SNI"
                                       FontSize="11" FontWeight="SemiBold" Opacity="0.7"
                                       VerticalAlignment="Center" />
                            <Border Grid.Column="1" Style="{StaticResource UI.MonoPill}">
                                <TextBlock Style="{StaticResource UI.MonoText}"
                                           Text="{Binding CurrentRouteSni}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="SNI hostname tunnel-core is currently presenting to the CDN" />
                            </Border>
                            <Button Grid.Column="2"
                                    Style="{StaticResource UI.IconButton}"
                                    Margin="4,0,0,0"
                                    ToolTip="Copy current SNI"
                                    Command="{Binding CopyCurrentSniCommand}">
                                <materialDesign:PackIcon Kind="ContentCopy" Width="15" Height="15" />
                            </Button>
                        </Grid>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
