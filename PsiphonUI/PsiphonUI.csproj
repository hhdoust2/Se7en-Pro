<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
    <SupportedOSPlatformVersion>10.0.19041.0</SupportedOSPlatformVersion>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>

    <NoWarn>$(NoWarn);WFAC010</NoWarn>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <RootNamespace>PsiphonUI</RootNamespace>
    <AssemblyName>PsiphonUI</AssemblyName>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <Platforms>x64;x86;AnyCPU</Platforms>
    <PlatformTarget>x64</PlatformTarget>
    <RuntimeIdentifiers>win-x64;win-x86</RuntimeIdentifiers>
    <UseAppHost>true</UseAppHost>
    <Version>1.0.1</Version>
    <AssemblyVersion>1.0.1.0</AssemblyVersion>
    <FileVersion>1.0.1.0</FileVersion>
    <Product>PsiphonUI</Product>
    <Company>PsiphonUI</Company>
    <Description>PsiphonUI — modern Windows client (sample/open-source build)</Description>

    <ApplicationIcon>Assets\app.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="MaterialDesignThemes" Version="5.2.1" />
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="8.0.1" />
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="8.0.1" />
    <PackageReference Include="Microsoft.Extensions.Logging" Version="8.0.1" />
    <PackageReference Include="Microsoft.Extensions.Logging.Debug" Version="8.0.1" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" Version="8.0.1" />
    <PackageReference Include="Microsoft.Win32.Registry" Version="5.0.0" />
    <PackageReference Include="System.Text.Json" Version="8.0.5" />
  </ItemGroup>

  <ItemGroup>
    <None Include="Resources\psiphon-tunnel-core.exe" Condition="Exists('Resources\psiphon-tunnel-core.exe')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="Resources\server_entries.txt" Condition="Exists('Resources\server_entries.txt')">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </None>
    <EmbeddedResource Include="Resources\server_entries.bin" Condition="Exists('Resources\server_entries.bin')">
      <LogicalName>PsiphonUI.Resources.server_entries.bin</LogicalName>
    </EmbeddedResource>

    <Content Include="Resources\sing-box\sing-box.exe" Condition="Exists('Resources\sing-box\sing-box.exe')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="Resources\sing-box\wintun.dll" Condition="Exists('Resources\sing-box\wintun.dll')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>

    <EmbeddedResource Include="Resources\akamai_seed_ips.txt" />
    <EmbeddedResource Include="Resources\akamai_ip_ranges.txt" />
    <EmbeddedResource Include="Resources\cloudflare_ip_ranges.txt" />
    <EmbeddedResource Include="Resources\fastly_ip_ranges.txt" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Assets\**\*" />
    <Resource Include="Resources\Flags\*.png" />
  </ItemGroup>

</Project>
